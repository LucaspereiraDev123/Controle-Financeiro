APP_NAME="Economiza Certo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=desafio_controle_financeiro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Os e-mails de verificação/reset são enfileirados (ShouldQueue). Com a fila
# `database`, é preciso um worker ativo para que os e-mails saiam:
#   php artisan queue:work
# Em dev, para enviar de forma síncrona sem worker, use QUEUE_CONNECTION=sync.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==================== E-MAIL ====================
# DEV sem credenciais: MAIL_MAILER=log  (o link cai em storage/logs/laravel.log)
#
# DEV/teste (Mailtrap sandbox — captura sem entregar):
#   MAIL_MAILER=smtp
#   MAIL_HOST=sandbox.smtp.mailtrap.io
#   MAIL_PORT=2525
#   MAIL_USERNAME / MAIL_PASSWORD = credenciais da sua Inbox no Mailtrap
#
# PRODUÇÃO (Brevo — entrega de verdade) via SMTP:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp-relay.brevo.com
#   MAIL_PORT=587
#   MAIL_SCHEME=null            (587 usa STARTTLS automaticamente)
#   MAIL_USERNAME=<seu login SMTP do Brevo>   (SMTP & API → SMTP)
#   MAIL_PASSWORD=<sua SMTP key do Brevo>     (NÃO é a senha da conta)
#   MAIL_FROM_ADDRESS="nao-responda@economizacerto.com.br"  (domínio verificado no Brevo)
#
# ENTREGABILIDADE (obrigatório em produção para não cair em spam):
#   1) No Brevo: Senders, Domains & Dedicated IPs → autenticar o domínio economizacerto.com.br
#   2) Publicar no DNS do domínio os registros que o Brevo mostrar: SPF, DKIM e (idealmente) DMARC
#   3) O MAIL_FROM_ADDRESS deve usar esse domínio autenticado
#   Enquanto o domínio não está autenticado, dá para testar com um "sender" avulso validado.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="nao-responda@economizacerto.com.br"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mercado Pago (assinatura recorrente). Pegue as credenciais de TESTE em
# https://www.mercadopago.com.br/developers → Suas integrações → Credenciais.
# Em produção, troque pelas credenciais de produção. Deixe vazio para desativar.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_PLANO_VALOR=19.90
MP_PLANO_NOME="Assinatura Economiza Certo"

VITE_APP_NAME="${APP_NAME}"
